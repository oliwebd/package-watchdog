{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["src/ambient.d.ts", "src/**/*", "build.ts"],
  "exclude": ["node_modules"]
}
